<UserControl x:Class="Presentation.Views.StudentCourseListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White" Padding="20">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<!-- Chứa Tiêu đề + Error Message -->
			<RowDefinition Height="*"/>
			<!-- Chứa Danh sách khóa học -->
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Phần Header: Gói vào StackPanel để không bị đè UI lên nhau -->
		<StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,15">
			<TextBlock Text="Các khóa học của bạn" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

			<!-- Error Message -->
			<Border Background="#FFE6E6" Padding="10" CornerRadius="4"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
				<TextBlock Text="{Binding ErrorMessage}" Foreground="#C00" FontSize="12" TextWrapping="Wrap"/>
			</Border>
		</StackPanel>

		<!-- Course List -->
		<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
			<ItemsControl ItemsSource="{Binding Courses}">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Background="#F9F9F9" BorderBrush="#DDD" BorderThickness="1"
                                Padding="15" Margin="0,0,0,10" CornerRadius="5">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>

								<StackPanel Grid.Column="0" Orientation="Vertical">
									<TextBlock Text="{Binding Course.Title}" FontSize="14" FontWeight="Bold" TextWrapping="Wrap"/>
									<TextBlock Text="{Binding Course.Description}" FontSize="12" Foreground="#666"
                                               Margin="0,5,0,3" TextWrapping="Wrap"/>
									<TextBlock FontSize="11" Foreground="#999">
										<Run Text="Giáo viên: "/>
										<Run Text="{Binding Course.Instructor.FullName, TargetNullValue='Chưa phân công'}"/>
									</TextBlock>
									<ProgressBar Value="{Binding Progress}" Maximum="100" Height="8"
                                                 Margin="0,8,0,0" Background="#EEE" Foreground="#27AE60"/>
								</StackPanel>

								<StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" Margin="15,0,0,0">
									<TextBlock Text="{Binding Progress, StringFormat={}{0}%}"
                                               FontSize="12" Foreground="#27AE60" FontWeight="Bold"
                                               TextAlignment="Center"/>
								</StackPanel>
							</Grid>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>

		<!-- Loading Indicator -->
		<StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding IsLoading, Converter={StaticResource StringToVisibilityConverter}}">
			<TextBlock Text="Đang tải..." Foreground="#999" FontSize="14"/>
		</StackPanel>

		<!-- Empty State (Lưu ý: Đảm bảo Converter xử lý đúng kiểu int của Courses.Count) -->
		<TextBlock Grid.Row="1" Text="Bạn chưa đăng ký khóa học nào" Foreground="#999"
                   HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"
                   Visibility="{Binding Courses.Count, Converter={StaticResource StringToVisibilityConverter}}"/>
	</Grid>
</UserControl>