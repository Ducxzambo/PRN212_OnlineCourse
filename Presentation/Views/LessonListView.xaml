<UserControl x:Class="Presentation.Views.LessonListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="&#8592; Quay lại" Command="{Binding BackCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,12,0"/>
            <StackPanel>
                <TextBlock Text="{Binding Course.Title}" Style="{StaticResource HeadingText}"/>
                <TextBlock Text="Danh sách bài học của khóa học" Style="{StaticResource SubHeadingText}" Margin="0,4,0,0"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,12">
            <Button Content="+ Thêm bài học" Command="{Binding AddCommand}"/>
        </StackPanel>

        <DataGrid Grid.Row="2" ItemsSource="{Binding Lessons}" SelectedItem="{Binding SelectedLesson}"
                  MinHeight="160" MaxHeight="420">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#" Binding="{Binding OrderIndex}" Width="40"/>
                <DataGridTextColumn Header="Tên bài học" Binding="{Binding Title}" Width="2*"/>
                <DataGridTextColumn Header="Link video" Binding="{Binding VideoUrl}" Width="2*"/>
                <DataGridTextColumn Header="Thời lượng (phút)" Binding="{Binding DurationMinutes}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="&#8593; Lên" Command="{Binding MoveUpCommand}" Style="{StaticResource SecondaryButton}"/>
            <Button Content="&#8595; Xuống" Command="{Binding MoveDownCommand}" Style="{StaticResource SecondaryButton}"/>
            <Button Content="Sửa" Command="{Binding EditCommand}" Style="{StaticResource SecondaryButton}"/>
            <Button Content="Xóa" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}"/>
        </StackPanel>
    </Grid>
</UserControl>
