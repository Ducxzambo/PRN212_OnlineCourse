<UserControl x:Class="Presentation.Views.AccountListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="AccountsGrid" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="MinHeight" Value="160"/>
            <Setter Property="MaxHeight" Value="420"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Tài khoản" Style="{StaticResource HeadingText}"/>
            <TextBlock Text="Quản lý tài khoản Instructor và Student" Style="{StaticResource SubHeadingText}" Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="Tìm kiếm:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Height="34" Width="280"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Làm mới" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}"/>
                <Button Content="+ Thêm tài khoản" Command="{Binding AddCommand}"/>
            </StackPanel>
        </Grid>

        <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0">

            <!-- Instructor accounts -->
            <TabItem Header="Instructor">
                <DataGrid Style="{StaticResource AccountsGrid}" Margin="0,10,0,0"
                          ItemsSource="{Binding InstructorAccounts}" SelectedItem="{Binding SelectedAccount}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Họ tên" Binding="{Binding FullName}" Width="1.6*"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.8*"/>
                        <DataGridTextColumn Header="Điện thoại" Binding="{Binding Instructor.Phone}" Width="120"/>
                        <DataGridCheckBoxColumn Header="Đang hoạt động" Binding="{Binding IsActive}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Student accounts -->
            <TabItem Header="Student">
                <DataGrid Style="{StaticResource AccountsGrid}" Margin="0,10,0,0"
                          ItemsSource="{Binding StudentAccounts}" SelectedItem="{Binding SelectedAccount}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Họ tên" Binding="{Binding FullName}" Width="1.6*"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.8*"/>
                        <DataGridTextColumn Header="Điện thoại" Binding="{Binding Student.Phone}" Width="120"/>
                        <DataGridCheckBoxColumn Header="Đang hoạt động" Binding="{Binding IsActive}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Admin accounts - read only, edit/delete blocked in code-behind too -->
            <TabItem Header="Admin">
                <DataGrid Style="{StaticResource AccountsGrid}" Margin="0,10,0,0"
                          ItemsSource="{Binding AdminAccounts}" SelectedItem="{Binding SelectedAccount}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Họ tên" Binding="{Binding FullName}" Width="1.6*"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.8*"/>
                        <DataGridCheckBoxColumn Header="Đang hoạt động" Binding="{Binding IsActive}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Xem chi tiết" Command="{Binding ViewDetailsCommand}" Style="{StaticResource SecondaryButton}"/>
            <Button Content="Sửa" Command="{Binding EditCommand}" Style="{StaticResource SecondaryButton}"/>
            <Button Content="Xóa" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}"/>
        </StackPanel>
    </Grid>
</UserControl>
