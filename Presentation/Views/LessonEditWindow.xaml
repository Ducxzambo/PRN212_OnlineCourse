<Window x:Class="Presentation.Views.LessonEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}" Height="500" Width="460"
        MinHeight="360" MinWidth="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="{Binding WindowTitle}" Style="{StaticResource HeadingText}" Margin="0,0,0,16"/>

                <TextBlock Text="Tên bài học" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Height="34" Margin="0,0,0,10"/>

                <TextBlock Text="Nội dung" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                         Height="90" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>

                <TextBlock Text="Link video" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding VideoUrl, UpdateSourceTrigger=PropertyChanged}" Height="34" Margin="0,0,0,10"/>

                <TextBlock Text="Thời lượng (phút)" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding DurationMinutes, UpdateSourceTrigger=PropertyChanged}" Height="34" Width="140" HorizontalAlignment="Left" Margin="0,0,0,10"/>

                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorText}"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Hủy" IsCancel="True" Style="{StaticResource SecondaryButton}"/>
            <Button Content="Lưu" Command="{Binding SaveCommand}" IsDefault="True" MinWidth="90"/>
        </StackPanel>
    </Grid>
</Window>
