<UserControl x:Class="Presentation.Views.AdminCourseListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Khóa học &amp; bài học" Style="{StaticResource HeadingText}"/>
            <TextBlock Text="Xem danh sách khóa học và bài học; Admin không thể chỉnh sửa dữ liệu tại đây." Style="{StaticResource SubHeadingText}" Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Tìm kiếm:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Height="34" Width="300"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Làm mới" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}"/>
        </Grid>

        <DataGrid Grid.Row="2" ItemsSource="{Binding Courses}" SelectedItem="{Binding SelectedCourse}" MinHeight="160" MaxHeight="480">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tên khóa học" Binding="{Binding Title}" Width="2*"/>
                <DataGridTextColumn Header="Danh mục" Binding="{Binding Category.Name}" Width="*"/>
                <DataGridTextColumn Header="Giảng viên" Binding="{Binding Instructor.Account.FullName}" Width="*"/>
                <DataGridTextColumn Header="Giá" Binding="{Binding Price, StringFormat={}{0:N2}}" Width="90"/>
                <DataGridTextColumn Header="Số giờ" Binding="{Binding DurationHours}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Xem bài học" Command="{Binding ViewLessonsCommand}" Style="{StaticResource SecondaryButton}"/>
        </StackPanel>
    </Grid>
</UserControl>
