<UserControl x:Class="Presentation.Views.CategoryListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Danh mục khóa học" Style="{StaticResource HeadingText}"/>
            <TextBlock Text="Quản lý các danh mục dùng để phân loại khóa học" Style="{StaticResource SubHeadingText}" Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="Tìm kiếm:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Height="34" Width="280"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Làm mới" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}"/>
                <Button Content="+ Thêm danh mục" Command="{Binding AddCommand}"/>
            </StackPanel>
        </Grid>

        <DataGrid Grid.Row="2" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}"
                  MinHeight="140" MaxHeight="260">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tên danh mục" Binding="{Binding Name}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Sửa" Command="{Binding EditCommand}" Style="{StaticResource SecondaryButton}"/>
            <Button Content="Xóa" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}"/>
        </StackPanel>

        <!-- Courses that belong to the selected category -->
        <TextBlock Grid.Row="4" Margin="0,20,0,8">
            <Run Text="Khóa học thuộc danh mục" FontWeight="SemiBold"/>
            <Run Text="{Binding SelectedCategory.Name, StringFormat=' \u201c{0}\u201d', Mode=OneWay}" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold"/>
        </TextBlock>

        <DataGrid Grid.Row="5" ItemsSource="{Binding CoursesInCategory}" SelectedItem="{Binding SelectedCourseInCategory}" MinHeight="140" MaxHeight="260">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tên khóa học" Binding="{Binding Title}" Width="2*"/>
                <DataGridTextColumn Header="Giảng viên" Binding="{Binding Instructor.FullName}" Width="1.4*"/>
                <DataGridTextColumn Header="Giá" Binding="{Binding Price, StringFormat={}{0:N2}}" Width="90"/>
                <DataGridTextColumn Header="Số giờ" Binding="{Binding DurationHours}" Width="70"/>
                <DataGridTextColumn Header="Học viên" Binding="{Binding Enrollments.Count}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="6" Margin="0,20,0,0">
            <TextBlock Margin="0,0,0,8">
                <Run Text="Bài học của khóa học" FontWeight="SemiBold"/>
                <Run Text="{Binding SelectedCourseInCategory.Title, StringFormat=' “{0}”', Mode=OneWay}" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold"/>
            </TextBlock>
            <DataGrid ItemsSource="{Binding LessonsInSelectedCourse}" MinHeight="120" MaxHeight="260">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding OrderIndex}" Width="45"/>
                    <DataGridTextColumn Header="Tên bài học" Binding="{Binding Title}" Width="2*"/>
                    <DataGridTextColumn Header="Nội dung" Binding="{Binding Content}" Width="2*"/>
                    <DataGridTextColumn Header="Video" Binding="{Binding VideoUrl}" Width="2*"/>
                    <DataGridTextColumn Header="Phút" Binding="{Binding DurationMinutes}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</UserControl>
