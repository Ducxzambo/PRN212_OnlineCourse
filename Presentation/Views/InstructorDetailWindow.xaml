<Window x:Class="Presentation.Views.InstructorDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thông tin Instructor" Height="480" Width="620"
        MinHeight="320" MinWidth="480"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{Binding Instructor.FullName}" Style="{StaticResource HeadingText}"/>
            <TextBlock Text="{Binding Instructor.Email}" Style="{StaticResource SubHeadingText}" Margin="0,4,0,0"/>
            <TextBlock Text="{Binding Instructor.Phone}" Style="{StaticResource SubHeadingText}" Margin="0,2,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Khóa học phụ trách" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <DataGrid ItemsSource="{Binding Courses}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Khóa học" Binding="{Binding Title}" Width="2*"/>
                    <DataGridTextColumn Header="Danh mục" Binding="{Binding Category.Name}" Width="1.2*"/>
                    <DataGridTextColumn Header="Giá" Binding="{Binding Price, StringFormat={}{0:N2}}" Width="90"/>
                    <DataGridTextColumn Header="Học viên" Binding="{Binding Enrollments.Count}" Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Đóng" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
