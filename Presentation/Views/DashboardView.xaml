<UserControl x:Class="Presentation.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Thống kê hệ thống" Style="{StaticResource HeadingText}"/>
                <TextBlock Text="Tổng quan số liệu toàn hệ thống" Style="{StaticResource SubHeadingText}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Làm mới" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" VerticalAlignment="Bottom"/>
        </Grid>

        <!-- Summary cards -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="6" Margin="0,0,0,20">
            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,8,0" Padding="14">
                <StackPanel>
                    <TextBlock Text="{Binding Stats.TotalCategories}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="Danh mục" Style="{StaticResource SubHeadingText}"/>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,8,0" Padding="14">
                <StackPanel>
                    <TextBlock Text="{Binding Stats.TotalInstructors}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="Instructor" Style="{StaticResource SubHeadingText}"/>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,8,0" Padding="14">
                <StackPanel>
                    <TextBlock Text="{Binding Stats.TotalStudents}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="Học viên" Style="{StaticResource SubHeadingText}"/>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,8,0" Padding="14">
                <StackPanel>
                    <TextBlock Text="{Binding Stats.TotalCourses}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="Khóa học" Style="{StaticResource SubHeadingText}"/>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,8,0" Padding="14">
                <StackPanel>
                    <TextBlock Text="{Binding Stats.TotalLessons}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="Bài học" Style="{StaticResource SubHeadingText}"/>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="14">
                <StackPanel>
                    <TextBlock Text="{Binding Stats.TotalEnrollments}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="Lượt đăng ký" Style="{StaticResource SubHeadingText}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Enrollment status breakdown -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="16" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Trạng thái đăng ký" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <UniformGrid Rows="1" Columns="4">
                    <StackPanel>
                        <TextBlock Text="{Binding Stats.RegisteredEnrollments}" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Đã đăng ký" Style="{StaticResource SubHeadingText}"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="{Binding Stats.InProgressEnrollments}" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Đang học" Style="{StaticResource SubHeadingText}"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="{Binding Stats.CompletedEnrollments}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                        <TextBlock Text="Hoàn thành" Style="{StaticResource SubHeadingText}"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="{Binding Stats.CancelledEnrollments}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                        <TextBlock Text="Đã hủy" Style="{StaticResource SubHeadingText}"/>
                    </StackPanel>
                </UniformGrid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="16">
                <StackPanel>
                    <TextBlock Text="Khóa học theo danh mục" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <DataGrid ItemsSource="{Binding CoursesByCategory}" MaxHeight="240">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Danh mục" Binding="{Binding CategoryName}" Width="*"/>
                            <DataGridTextColumn Header="Số khóa học" Binding="{Binding CourseCount}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="16">
                <StackPanel>
                    <TextBlock Text="Top khóa học nhiều học viên nhất" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <DataGrid ItemsSource="{Binding TopCourses}" MaxHeight="240">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Khóa học" Binding="{Binding CourseTitle}" Width="1.6*"/>
                            <DataGridTextColumn Header="Giảng viên" Binding="{Binding InstructorName}" Width="1.2*"/>
                            <DataGridTextColumn Header="Học viên" Binding="{Binding EnrollmentCount}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
