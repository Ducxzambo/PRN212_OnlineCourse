<Window x:Class="Presentation.Views.StudentMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Student Portal" Height="600" Width="900"
        Background="#F5F5F5">
    <DockPanel>
        <!-- Top Navigation Bar -->
        <Border DockPanel.Dock="Top" Background="#2C3E50" Padding="15">
            <Grid>
                <TextBlock Text="{Binding StudentName}" Foreground="White" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Khóa học" Command="{Binding NavigateCoursesCommand}"
                            Padding="10,5" Background="#3498DB" Foreground="White" Cursor="Hand" Margin="0,0,10,0"/>
                    <Button Content="Tiến độ" Command="{Binding NavigateProgressCommand}"
                            Padding="10,5" Background="#3498DB" Foreground="White" Cursor="Hand" Margin="0,0,10,0"/>
                    <Button Content="Đăng xuất" Command="{Binding LogoutCommand}"
                            Padding="10,5" Background="#E74C3C" Foreground="White" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <ContentControl DockPanel.Dock="Bottom" Content="{Binding CurrentViewModel}"
                       Margin="0" Height="Auto"/>
    </DockPanel>
</Window>
