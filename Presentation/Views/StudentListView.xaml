<UserControl x:Class="Presentation.Views.StudentListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Học viên" Style="{StaticResource HeadingText}"/>
            <TextBlock Text="Danh sách học viên đã đăng ký các khóa học của bạn" Style="{StaticResource SubHeadingText}" Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="Tìm kiếm:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Height="34" Width="220" Margin="0,0,16,0"/>

                <TextBlock Text="Khóa học:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding CourseFilters}" SelectedItem="{Binding SelectedCourseFilter}"
                          DisplayMemberPath="DisplayName" Height="34" Width="220"/>
            </StackPanel>

            <Button Grid.Column="1" Content="Làm mới" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}"/>
        </Grid>

        <DataGrid Grid.Row="2" ItemsSource="{Binding Enrollments}" SelectedItem="{Binding SelectedEnrollment}"
                  MinHeight="160" MaxHeight="320" Margin="0,0,0,16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Họ tên" Binding="{Binding Student.FullName}" Width="1.4*"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Student.Email}" Width="1.6*"/>
                <DataGridTextColumn Header="Điện thoại" Binding="{Binding Student.Phone}" Width="120"/>
                <DataGridTextColumn Header="Khóa học" Binding="{Binding Course.Title}" Width="1.6*"/>
                <DataGridTextColumn Header="Ngày đăng ký" Binding="{Binding EnrollDate, StringFormat={}{0:dd/MM/yyyy}}" Width="110"/>
                <DataGridTextColumn Header="Trạng thái"
                                     Binding="{Binding Status, Converter={StaticResource EnrollmentStatusConverter}}"
                                     Width="110"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3" Text="Thao tác với lượt đăng ký đã chọn" Style="{StaticResource SubHeadingText}" Margin="0,16,0,8"/>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Cập nhật trạng thái / gỡ đăng ký">
                <StackPanel>
                    <TextBlock Text="Trạng thái mới" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding StatusOptions}" SelectedValue="{Binding SelectedStatusValue}"
                              SelectedValuePath="Value" DisplayMemberPath="Text" Height="34"/>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Cập nhật trạng thái" Command="{Binding UpdateStatusCommand}"/>
                        <Button Content="Xem lịch sử" Command="{Binding ViewHistoryCommand}" Style="{StaticResource SecondaryButton}"/>
                        <Button Content="Xóa đăng ký" Command="{Binding RemoveEnrollmentCommand}" Style="{StaticResource DangerButton}"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Ghi danh học viên vào khóa học">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Họ tên" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Row="1" Text="{Binding NewStudentFullName, UpdateSourceTrigger=PropertyChanged}" Height="30" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="2" Text="Email" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Row="3" Text="{Binding NewStudentEmail, UpdateSourceTrigger=PropertyChanged}" Height="30" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="4" Text="Điện thoại (tùy chọn)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Row="5" Text="{Binding NewStudentPhone, UpdateSourceTrigger=PropertyChanged}" Height="30" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="6" Text="Khóa học" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Grid.Row="7" ItemsSource="{Binding MyCourses}" SelectedItem="{Binding SelectedEnrollCourse}"
                              DisplayMemberPath="Title" Height="30" Margin="0,0,0,10"/>

                    <Button Grid.Row="8" Content="Ghi danh" Command="{Binding EnrollCommand}" HorizontalAlignment="Left"/>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
