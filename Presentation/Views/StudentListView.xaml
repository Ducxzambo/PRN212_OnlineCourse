<UserControl x:Class="Presentation.Views.StudentListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Học viên" Style="{StaticResource HeadingText}"/>
            <TextBlock Text="Xem trạng thái đăng ký và tiến độ bài học của học viên trong các khóa học của bạn" Style="{StaticResource SubHeadingText}" Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Tìm kiếm:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Height="34" Width="220" Margin="0,0,16,0"/>
                <TextBlock Text="Khóa học:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding CourseFilters}" SelectedItem="{Binding SelectedCourseFilter}" DisplayMemberPath="DisplayName" Height="34" Width="220"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Làm mới" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}"/>
        </Grid>

        <DataGrid Grid.Row="2" ItemsSource="{Binding Enrollments}" SelectedItem="{Binding SelectedEnrollment}" MinHeight="160" MaxHeight="440">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Họ tên" Binding="{Binding Student.FullName}" Width="1.4*"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Student.Email}" Width="1.6*"/>
                <DataGridTextColumn Header="Điện thoại" Binding="{Binding Student.Phone}" Width="120"/>
                <DataGridTextColumn Header="Khóa học" Binding="{Binding Course.Title}" Width="1.6*"/>
                <DataGridTemplateColumn Header="Tiến độ" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Margin="4,0"><ProgressBar Value="{Binding Progress}" Maximum="100" Height="16"/><TextBlock Text="{Binding Progress, StringFormat={}{0:N0}%}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/></Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status, Converter={StaticResource EnrollmentStatusConverter}}" Width="110"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Xem tiến độ bài học" Command="{Binding ViewProgressCommand}" Style="{StaticResource SecondaryButton}"/>
        </StackPanel>
    </Grid>
</UserControl>
