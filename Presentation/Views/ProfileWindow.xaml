<Window x:Class="Presentation.Views.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hồ sơ cá nhân" Height="570" Width="460" WindowStartupLocation="CenterOwner">
    <Grid Margin="24"><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <ScrollViewer><StackPanel>
            <TextBlock Text="Hồ sơ cá nhân" Style="{StaticResource HeadingText}" Margin="0,0,0,16"/>
            <TextBlock Text="Vai trò" Style="{StaticResource FieldLabel}"/><TextBox Text="{Binding RoleName, Mode=OneWay}" IsReadOnly="True" Height="34" Margin="0,0,0,10"/>
            <TextBlock Text="Ngày tạo" Style="{StaticResource FieldLabel}"/><TextBox Text="{Binding CreatedDate, Mode=OneWay}" IsReadOnly="True" Height="34" Margin="0,0,0,10"/>
            <TextBlock Text="Họ tên" Style="{StaticResource FieldLabel}"/><TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Height="34" Margin="0,0,0,10"/>
            <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/><TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Height="34" Margin="0,0,0,10"/>
            <TextBlock Text="Mật khẩu mới (để trống nếu không đổi)" Style="{StaticResource FieldLabel}"/><PasswordBox PasswordChanged="PasswordBox_PasswordChanged" Height="34" Margin="0,0,0,10"/>
            <TextBlock Text="Điện thoại" Style="{StaticResource FieldLabel}"/><TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Height="34" Margin="0,0,0,10"/>
            <StackPanel Visibility="{Binding IsInstructor, Converter={StaticResource BooleanToVisibilityConverter}}"><TextBlock Text="Chuyên môn" Style="{StaticResource FieldLabel}"/><TextBox Text="{Binding Specialization, UpdateSourceTrigger=PropertyChanged}" Height="34" Margin="0,0,0,10"/></StackPanel>
            <StackPanel Visibility="{Binding IsStudent, Converter={StaticResource BooleanToVisibilityConverter}}"><TextBlock Text="Ngày sinh" Style="{StaticResource FieldLabel}"/><DatePicker SelectedDate="{Binding DateOfBirth}" Height="34" Margin="0,0,0,10"/></StackPanel>
            <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorText}" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
        </StackPanel></ScrollViewer>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0"><Button Content="Hủy" IsCancel="True" Style="{StaticResource SecondaryButton}"/><Button Content="Lưu" Command="{Binding SaveCommand}" IsDefault="True"/></StackPanel>
    </Grid>
</Window>
