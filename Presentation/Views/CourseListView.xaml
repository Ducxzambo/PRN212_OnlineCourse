<UserControl x:Class="Presentation.Views.CourseListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Khóa học của tôi" Style="{StaticResource HeadingText}"/>
            <TextBlock Text="Quản lý các khóa học bạn phụ trách" Style="{StaticResource SubHeadingText}" Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="Tìm kiếm:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Height="34" Width="280"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Làm mới" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}"/>
                <Button Content="+ Thêm khóa học" Command="{Binding AddCommand}"/>
            </StackPanel>
        </Grid>

        <DataGrid Grid.Row="2" ItemsSource="{Binding Courses}" SelectedItem="{Binding SelectedCourse}"
                  MinHeight="160" MaxHeight="420">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tên khóa học" Binding="{Binding Title}" Width="2*"/>
                <DataGridTextColumn Header="Danh mục" Binding="{Binding Category.Name}" Width="*"/>
                <DataGridTextColumn Header="Giá" Binding="{Binding Price, StringFormat={}{0:N2}}" Width="90"/>
                <DataGridTextColumn Header="Số giờ" Binding="{Binding DurationHours}" Width="70"/>
                <DataGridTextColumn Header="Ngày tạo" Binding="{Binding CreatedDate, StringFormat={}{0:dd/MM/yyyy}}" Width="100"/>
                <DataGridTextColumn Header="Bài học" Binding="{Binding Lessons.Count}" Width="80"/>
                <DataGridTextColumn Header="Học viên" Binding="{Binding Enrollments.Count}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Quản lý bài học" Command="{Binding ManageLessonsCommand}" Style="{StaticResource SecondaryButton}"/>
            <Button Content="Sửa" Command="{Binding EditCommand}" Style="{StaticResource SecondaryButton}"/>
            <Button Content="Xóa" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}"/>
        </StackPanel>
    </Grid>
</UserControl>
