<Window x:Class="Presentation.Views.StudentDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lịch sử học viên" Height="480" Width="620"
        MinHeight="320" MinWidth="480"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{Binding Student.FullName}" Style="{StaticResource HeadingText}"/>
            <TextBlock Text="{Binding Student.Email}" Style="{StaticResource SubHeadingText}" Margin="0,4,0,0"/>
        </StackPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding History}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Khóa học" Binding="{Binding Course.Title}" Width="2*"/>
                <DataGridTextColumn Header="Danh mục" Binding="{Binding Course.Category.Name}" Width="1.2*"/>
                <DataGridTextColumn Header="Giảng viên" Binding="{Binding Course.Instructor.FullName}" Width="1.4*"/>
                <DataGridTextColumn Header="Ngày đăng ký" Binding="{Binding EnrollDate, StringFormat={}{0:dd/MM/yyyy}}" Width="110"/>
                <DataGridTextColumn Header="Trạng thái"
                                     Binding="{Binding Status, Converter={StaticResource EnrollmentStatusConverter}}"
                                     Width="110"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Đóng" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
