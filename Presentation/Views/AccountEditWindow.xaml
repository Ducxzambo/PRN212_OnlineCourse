<Window x:Class="Presentation.Views.AccountEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}" Height="500" Width="460"
        MinHeight="420" MinWidth="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="{Binding WindowTitle}" Style="{StaticResource HeadingText}" Margin="0,0,0,16"/>

                <TextBlock Text="Họ tên" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Height="34" Margin="0,0,0,10"/>

                <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Height="34" Margin="0,0,0,10"/>

                <TextBlock Text="Điện thoại (Instructor / Student)" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Height="34" Margin="0,0,0,10"/>

                <TextBlock Text="Vai trò" Style="{StaticResource FieldLabel}"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10"
                            IsEnabled="{Binding CanChangeRole}">
                    <RadioButton Content="Instructor" IsChecked="{Binding IsInstructorRole}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                    <RadioButton Content="Student" IsChecked="{Binding IsStudentRole}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                    <RadioButton Content="Admin" IsChecked="{Binding IsAdminRole}" VerticalAlignment="Center"/>
                </StackPanel>

                <CheckBox Content="Đang hoạt động" IsChecked="{Binding IsActive}" Margin="0,0,0,10"/>

                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorText}"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Hủy" IsCancel="True" Style="{StaticResource SecondaryButton}"/>
            <Button Content="Lưu" Command="{Binding SaveCommand}" IsDefault="True" MinWidth="90"/>
        </StackPanel>
    </Grid>
</Window>
